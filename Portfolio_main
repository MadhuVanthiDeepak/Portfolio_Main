  color:var(--text);
  position:relative;overflow:hidden;
  transition:transform .35s,border-color .35s,box-shadow .35s;
  -webkit-tap-highlight-color:transparent;
  cursor:none;
}
/* sweep top border on hover */
.soc-card::before{
  content:'';position:absolute;top:0;left:-110%;width:100%;height:2.5px;
