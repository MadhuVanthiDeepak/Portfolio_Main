<script>
/* ============================================================
   LOADER
============================================================ */
window.addEventListener('load',()=>{
  setTimeout(()=>document.getElementById('loader').classList.add('out'),2200);
});

/* ============================================================
   CUSTOM CURSOR
============================================================ */
const dot=document.getElementById('cur-dot');
const ring=document.getElementById('cur-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;});
(function tick(){
  dot.style.cssText=`left:${mx}px;top:${my}px;`;
  rx+=(mx-rx)*.11; ry+=(my-ry)*.11;
  ring.style.cssText=`left:${rx}px;top:${ry}px;`;
  requestAnimationFrame(tick);
})();
const hoverEls=document.querySelectorAll('a,button,.btn,.pc-btn,.proj-card,.co-card,.edu-card,.s-card,.cert-card,.tilt-card,.soc-link,.soc-card,.co-soc-link');
hoverEls.forEach(el=>{
  el.addEventListener('mouseenter',()=>document.body.classList.add('cursor-grow'));
  el.addEventListener('mouseleave',()=>document.body.classList.remove('cursor-grow'));
});

/* ============================================================
   PARTICLE CANVAS
============================================================ */
const cv=document.getElementById('cv');
const ctx=cv.getContext('2d');
function resize(){cv.width=innerWidth;cv.height=innerHeight;}
resize(); window.addEventListener('resize',resize);

const COLS=['rgba(255,45,149,','rgba(0,229,255,','rgba(255,200,87,','rgba(124,58,237,'];
const N=Math.min(70,Math.round(innerWidth/16));
const pts=Array.from({length:N},()=>({
  x:Math.random()*innerWidth,
  y:Math.random()*innerHeight,
  vx:(Math.random()-.5)*.45,
  vy:(Math.random()-.5)*.45,
  r:Math.random()*2+.8,
  c:COLS[Math.random()*COLS.length|0]
}));

function draw(){
  ctx.clearRect(0,0,cv.width,cv.height);
  pts.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy;
    if(p.x<0||p.x>cv.width)p.vx*=-1;
    if(p.y<0||p.y>cv.height)p.vy*=-1;
    ctx.beginPath();
    ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
    ctx.fillStyle=p.c+'0.75)';
    ctx.fill();
  });
  for(let i=0;i<pts.length;i++){
    for(let j=i+1;j<pts.length;j++){
      const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y;
      const d=Math.sqrt(dx*dx+dy*dy);
      if(d<130){
        ctx.beginPath();
        ctx.moveTo(pts[i].x,pts[i].y);
        ctx.lineTo(pts[j].x,pts[j].y);
        ctx.strokeStyle=pts[i].c+(1-d/130)*.2+')';
        ctx.lineWidth=.6;
        ctx.stroke();
      }
    }
  }
  requestAnimationFrame(draw);
}
draw();

/* ============================================================
   HERO CARD — TILT ON MOUSE
============================================================ */
const tiltWrap=document.getElementById('tilt-wrap');
const tiltCard=document.getElementById('tilt-card');
if(tiltWrap){
  tiltWrap.addEventListener('mousemove',e=>{
    const r=tiltWrap.getBoundingClientRect();
    const cx=r.left+r.width/2, cy=r.top+r.height/2;
    const rx2=(e.clientY-cy)/r.height*22;
    const ry2=-(e.clientX-cx)/r.width*22;
    tiltCard.style.animation='none';
    tiltCard.style.transform=`rotateX(${rx2}deg) rotateY(${ry2}deg) translateY(-6px)`;
  });
  tiltWrap.addEventListener('mouseleave',()=>{
    tiltCard.style.transform='';
    tiltCard.style.animation='float 6s ease-in-out infinite';
  });
}

/* ============================================================
   SCROLL REVEAL
============================================================ */
const revEls=document.querySelectorAll('.rv');
const revObs=new IntersectionObserver(entries=>{
  entries.forEach(en=>{if(en.isIntersecting)en.target.classList.add('on');});
},{threshold:.1});
revEls.forEach(el=>revObs.observe(el));

/* ============================================================
   SKILL BARS
============================================================ */
const fills=document.querySelectorAll('.sk-fill');
const barObs=new IntersectionObserver(entries=>{
  entries.forEach(en=>{
    if(en.isIntersecting){
      en.target.style.width=en.target.dataset.w+'%';
      barObs.unobserve(en.target);
    }
  });
},{threshold:.3});
fills.forEach(f=>barObs.observe(f));

/* ============================================================
   MOBILE NAV
============================================================ */
const burger=document.getElementById('burger');
const nl=document.getElementById('nl');
burger.addEventListener('click',()=>nl.classList.toggle('open'));
nl.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>nl.classList.remove('open')));
</script>
