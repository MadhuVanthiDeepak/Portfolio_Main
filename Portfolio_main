}
.co-card:hover{transform:translateX(10px);border-color:var(--pink);}
.co-ico{
  width:44px;height:44px;border-radius:12px;
  display:flex;align-items:center;justify-content:center;font-size:1.05rem;flex-shrink:0;
}
.co-lbl{font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;}
.co-val{font-size:.88rem;font-weight:500;color:var(--text);margin-top:2px;}

/* ripple avatar */
.rip-wrap{position:relative;width:180px;height:180px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.rip{
  position:absolute;border-radius:50%;
  border:1.5px solid rgba(255,45,149,.45);
  animation:rip-out 2.8s ease-out infinite;
}
.rip:nth-child(1){width:100%;height:100%;animation-delay:0s;}
.rip:nth-child(2){width:135%;height:135%;animation-delay:.9s;}
.rip:nth-child(3){width:170%;height:170%;animation-delay:1.8s;}
@keyframes rip-out{
  0%{transform:scale(.75);opacity:.9;}
  100%{transform:scale(1.1);opacity:0;}
}
.rip-av{
  width:104px;height:104px;border-radius:50%;
  background:linear-gradient(135deg,var(--pink),var(--violet));
  display:flex;align-items:center;justify-content:center;
  font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:#fff;
  position:relative;z-index:1;
  box-shadow:0 0 50px rgba(255,45,149,.45);
}

/* ======================================================
   FOOTER
====================================================== */
footer{
  border-top:1px solid var(--border);
  padding:1.8rem 6%;display:flex;align-items:center;justify-content:space-between;
  font-size:.78rem;color:var(--muted);position:relative;z-index:1;flex-wrap:wrap;gap:1rem;
}
.foot-logo{
  font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;
  background:linear-gradient(90deg,var(--pink),var(--cyan));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.foot-r{display:flex;align-items:center;gap:6px;}
.foot-heart{color:var(--pink);animation:hbeat .9s ease-in-out infinite alternate;}
@keyframes hbeat{from{transform:scale(1);}to{transform:scale(1.35);}}

/* ======================================================
   SOCIAL LINKS
====================================================== */

/* ── inline icon row (hero + footer) ── */
.soc-row{
  display:flex;align-items:center;gap:.75rem;
  flex-wrap:wrap;
}
.soc-link{
  position:relative;
  display:inline-flex;align-items:center;justify-content:center;
  width:44px;height:44px;border-radius:12px;
  background:rgba(255,255,255,.04);
  border:1px solid var(--border);
  color:var(--muted);
  text-decoration:none;
  transition:transform .3s,border-color .3s,box-shadow .3s,background .3s,color .3s;
  cursor:none;
  -webkit-tap-highlight-color:transparent;
}
.soc-link svg{width:20px;height:20px;display:block;transition:fill .3s;}
.soc-link:hover{transform:translateY(-4px) scale(1.12);}

/* per-platform glow colours */
.soc-linkedin:hover{
  border-color:rgba(10,102,194,.7);
  background:rgba(10,102,194,.12);
  color:#0a66c2;
  box-shadow:0 6px 28px rgba(10,102,194,.4);
}
.soc-github:hover{
  border-color:rgba(0,229,255,.6);
  background:rgba(0,229,255,.1);
  color:var(--cyan);
  box-shadow:0 6px 28px rgba(0,229,255,.35);
}
.soc-itch:hover{
  border-color:rgba(255,45,149,.6);
  background:rgba(255,45,149,.12);
  color:var(--pink);
  box-shadow:0 6px 28px rgba(255,45,149,.4);
}

/* tooltip */
.soc-link::after{
  content:attr(data-tip);
  position:absolute;bottom:calc(100% + 8px);left:50%;
  transform:translateX(-50%) translateY(4px);
  background:rgba(12,12,30,.95);
  color:var(--text);
  font-family:'DM Sans',sans-serif;
  font-size:.68rem;font-weight:500;
  white-space:nowrap;
  padding:4px 10px;border-radius:6px;
  border:1px solid var(--border);
  opacity:0;pointer-events:none;
  transition:opacity .2s,transform .2s;
}
.soc-link:hover::after{opacity:1;transform:translateX(-50%) translateY(0);}

/* ── Social section cards ── */
#social{padding-top:60px;padding-bottom:80px;}
.soc-cards{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:1.4rem;
}
.soc-card{
