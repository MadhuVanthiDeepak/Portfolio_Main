}
.cert-card:hover{border-color:var(--amber);transform:translateX(5px);}
.cert-ico{font-size:1.4rem;flex-shrink:0;}
.cert-nm{font-size:.84rem;font-weight:500;color:var(--text);line-height:1.4;}
